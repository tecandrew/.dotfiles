{
  "git_panel": {
    "tree_view": true
  },
  "use_system_path_prompts": false,
  "use_system_prompts": false,
  "colorize_brackets": true,
  "helix_mode": false,
  "language_models": {
    "openai_compatible": {
      "Cerebras": {
        "api_url": "https://api.cerebras.ai/v1",
        "available_models": [
          {
            "name": "zai-glm-4.7",
            "display_name": "cerebras/glm-4.7",
            "max_output_tokens": 40000,
            "max_tokens": 131000,
            "capabilities": {
              "images": false,
              "tools": true,
              "parallel_tool_calls": true,
              "prompt_cache_key": false, // cache flag in body not supported
            },
          },
          {
            "name": "gpt-oss-120b",
            "display_name": "cerebras/gpt-oss-120b",
            "max_output_tokens": 40000,
            "max_tokens": 131000,
            "capabilities": {
              "images": false,
              "tools": true,
              "parallel_tool_calls": true,
              "prompt_cache_key": false,
            },
          },
        ],
      },
    },
  },
  "completion_menu_scrollbar": "auto",
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "favorite_config_option_values": {
        "mode": [
          "auto"
        ]
      },
      "type": "registry"
    },
    "pi-acp": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry"
    }
  },
  "base_keymap": "VSCode",
  "buffer_font_weight": 400.0,
  "buffer_line_height": "standard",
  "inlay_hints": {
    "show_background": true,
    "enabled": false,
  },
  "project_panel": {
    "hide_gitignore": false,
  },
  "calls": {
    "mute_on_join": true,
  },
  "unnecessary_code_fade": 0.5,
  "tabs": {
    "file_icons": true,
  },
  "language_servers": ["!pylsp", "ruff", "!ty", "pyrefly", "!basedpyright", "!eslint"],
  "minimap": {
    "max_width_columns": 80,
    "current_line_highlight": "all",
    "thumb_border": "left_open",
    "thumb": "always",
    "display_in": "all_editors",
    "show": "never",
  },
  "show_whitespaces": "selection",
  "experimental.theme_overrides": {
    // "ghost_element.selected": "#FF0000"
  },
  "lsp": {
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "schemas": {
            "https://raw.githubusercontent.com/zarf-dev/zarf/main/zarf.schema.json": "zarf*.yaml",
            "https://raw.githubusercontent.com/defenseunicorns/maru-runner/refs/heads/main/tasks.schema.json": "tasks.yaml",
          },
        },
      },
    },
  },
  "format_on_save": "off",
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
    "active_line_width": 2,
  },
  "cursor_blink": true,
  "edit_predictions": {
    "sweep": {
      "privacy_mode": true
    },
    "provider": "codestral",
    "codestral": {
      "api_url": "https://codestral.mistral.ai",
      "model": "codestral-latest",
    },
    "disabled_globs": ["*.md", "*.env"],
    "mode": "subtle",
    "enabled_in_text_threads": false,
  },
  "show_edit_predictions": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "agent": {
    "inline_assistant_model": {
      "provider": "openrouter",
      "model": "z-ai/glm-5",
      "enable_thinking": false,
    },
    "default_model": {
      "effort": "high",
      "provider": "copilot_chat",
      "model": "gpt-5.4",
      "enable_thinking": false,
    },
    "tool_permissions": {
      "default": "allow",
    },
    "favorite_models": [
      {
        "provider": "Cerebras",
        "model": "zai-glm-4.7",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "moonshotai/kimi-k2.5",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "z-ai/glm-5",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.3-codex",
        "enable_thinking": true
      },
      {
        "provider": "copilot_chat",
        "model": "claude-opus-4.6",
        "enable_thinking": true
      },
      {
        "provider": "Cerebras",
        "model": "gpt-oss-120b",
        "enable_thinking": true
      },
      {
        "provider": "lmstudio",
        "model": "liquid/lfm2-24b-a2b",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.4",
        "enable_thinking": false
      }
    ],
    "default_profile": "write",
    "model_parameters": [],
    "play_sound_when_agent_done": "always",
  },
  "file_types": {
    "xml": ["*.mobileconfig"],
    "JSON": ["*.zedconfig", "*.json5"],
  },
  "vim_mode": true,
  "ui_font_family": "Monaspace Xenon Frozen",
  "buffer_font_family": "MonoLisa",
  "buffer_font_fallbacks": ["Monaspace Argon NF"],
  "buffer_font_features": {
    "ss03": true, // monolisa 'g'
    "zero": true, // monolisa slashed '0'
    "ss07": true, // monolisa curly bracket '{}'
    "ss10": true, // monolisa greater-than >=
    "ss11": true, // monolisa hexa-dec X '0xf'
    "ss14": true, // monolisa ampersand '&
    "ss15": true, // monolisa 'i'
    "ss16": true, // monolisa 'r'
  },
  "terminal": {
    "font_features": {
      "calt": true,
      "liga": false,
    },
    "font_size": 14.0,
    "font_family": "Monaspace Xenon NF",
    "font_fallbacks": ["Monaspace Argon NF"],
  },
  "ui_font_size": 15.0,
  "buffer_font_size": 15.0,
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "auto_install_extensions": {
    // themes
    "catppuccin": true,
    "catppuccin-icons": true,
    "dracula": true,
    // languages
    "html": true,
    "xml": true,
    "terraform": true,
    "pylsp": true,
    "dockerfile": true,
    "sql": true,
    "toml": true,
    // tools
    "just": true,
    "codebook": true,
    "oxc": true,
  },
}
